{
  "name": "@blind-dsai/ui",
  "version": "0.4.0",
  "description": "Chorus React components. Ships prebuilt ESM + CJS bundles (`dist/`) and a single `styles.css`; import `@blind-dsai/tokens/tokens.css` + `@blind-dsai/ui/styles.css` once at the app entry. The contract every component honors lives in schema/components/<family>/<sub>.spec.json; see schema/manifest.json for the inventory.",
  "license": "MIT",
  "author": "chorus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blind-dsai/chorus.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/blind-dsai/chorus#readme",
  "bugs": "https://github.com/blind-dsai/chorus/issues",
  "keywords": [
    "design-system",
    "react",
    "components",
    "chorus"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js",
      "require": "./dist/icons/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./agents/": "./agents/",
    "./agents/AGENTS.md": "./agents/AGENTS.md",
    "./agents/catalog.md": "./agents/catalog.md",
    "./agents/manifest.json": "./agents/manifest.json",
    "./agents/DESIGN.md": "./agents/DESIGN.md",
    "./agents/LOVABLE.md": "./agents/LOVABLE.md",
    "./agents/patterns/": "./agents/patterns/",
    "./agents/components/": "./agents/components/",
    "./agents/screens/": "./agents/screens/",
    "./placeholder_thumbnail.png": "./placeholder_thumbnail.png",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "agents",
    "placeholder_thumbnail.png",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "copy-agents": "node scripts/copy-agents.mjs",
    "prepublishOnly": "npm run copy-agents && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@blind-dsai/tokens": "^0.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
