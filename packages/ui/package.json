{
  "name": "@blind-dsai/ui",
  "version": "0.2.0",
  "description": "Chorus React components. Source-distributed (no prebuilt dist) — consumers compile JSX themselves and import `@blind-dsai/tokens/tokens.css` + `@blind-dsai/ui/styles.css` once at the app entry. The contract every component honors lives in schema/components/<family>/<sub>.spec.json; see schema/manifest.json for the inventory.",
  "license": "MIT",
  "author": "chorus",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blind-dsai/chorus.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/blind-dsai/chorus#readme",
  "bugs": "https://github.com/blind-dsai/chorus/issues",
  "keywords": [
    "design-system",
    "react",
    "components",
    "chorus"
  ],
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.js",
    "./icons": "./src/icons/index.js",
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@blind-dsai/tokens": "^0.2.0"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./icons": {
        "import": "./dist/icons/index.js",
        "require": "./dist/icons/index.cjs"
      },
      "./styles.css": "./dist/styles.css",
      "./package.json": "./package.json"
    }
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
