#!/usr/bin/env bash
# Pre-commit: currently a no-op stub.
#
# Until 2026-05, this hook regenerated lovable-export/import/ on every commit
# that touched schema/, patterns/, or packages/ui/src/. That flow is gone:
# Lovable now consumes Chorus via the npm packages @blind-dsai/ui +
# @blind-dsai/tokens, and the agent persona ships at @blind-dsai/ui/agents/
# (see packages/ui/scripts/copy-agents.mjs). No local artifact has to stay
# in sync with chorus source anymore, so there is nothing for this hook to
# do. The file is kept in place so `core.hooksPath` resolves successfully
# and future hooks can be added without re-wiring config.
#
# To bypass any future hook here (use sparingly): `git commit --no-verify`.

exit 0
