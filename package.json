{
  "name": "chorus",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "schema/*",
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm --workspace @blind-dsai/docs run dev",
    "build": "npm --workspace @blind-dsai/docs run build",
    "build:tokens": "node schema/tokens/build-resolved.mjs && node schema/tokens/build-usage.mjs",
    "build:usage": "node schema/tokens/build-usage.mjs",
    "build:ui": "npm --workspace @blind-dsai/ui run build",
    "build:packages": "npm run build:tokens && npm run build:ui",
    "lint:screens": "node schema/lint/validate-screen.mjs",
    "lint:tokens": "node schema/lint/validate-tokens.mjs",
    "lint:color-slots": "node schema/lint/validate-color-slots.mjs",
    "lint:layout-inset": "node schema/lint/validate-layout-inset.mjs",
    "lint": "npm run lint:screens && npm run lint:tokens && npm run lint:color-slots && npm run lint:layout-inset",
    "test:screens": "node schema/lint/test-screen.mjs",
    "build:icons": "node packages/ui/src/icons/build-icons.mjs",
    "prepare": "git config core.hooksPath .githooks || true",
    "mcp": "npm --workspace @blind-dsai/mcp-server run start",
    "test:mcp": "npm --workspace @blind-dsai/mcp-server run smoke",
    "test:visual": "npm --workspace @blind-dsai/visual-regression test",
    "test:visual:update": "npm --workspace @blind-dsai/visual-regression run update",
    "changeset": "changeset",
    "version-packages": "changeset version && npm install --package-lock-only",
    "release": "npm run build:packages && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
